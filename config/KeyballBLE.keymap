#define ZMK_POINTING_DEFAULT_SCRL_VAL 120    // default: 10

#include <dt-bindings/zmk/mouse.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define MOUSE 4
#define SCROLL 5
#define NUM 6

&msc {
    time-to-max-speed-ms = <0>;
    acceleration-exponent = <0>;
};

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

/ {
    combos {
        compatible = "zmk,combos";

        double_quotation {
            bindings = <&kp DOUBLE_QUOTES>;
            key-positions = <32 33>;
        };

        mb2_combo {
            bindings = <&mkp MB2>;
            key-positions = <19 18>;
        };

        scroll_combos {
            bindings = <&tog 5>;
            key-positions = <7 8>;
        };

        ps_photo_toggle {
            bindings = <&tog 8>;
            key-positions = <13 14>; /* F + G */
        };

        layer3_combos {
            bindings = <&tog 3>;
            key-positions = <17 18>;
        };

        layer2_combos {
            bindings = <&tog 2>;
            key-positions = <5 6>;
        };

        /* Drag ON (MB1 press) */

        bluetooth {
            bindings = <&mo 6>;
            key-positions = <39 38>;
        };

        drag_on_combo_2 {
            bindings = <&drag_off>;
            key-positions = <20 19>;
        };

        key1 {
            bindings = <&kp EXCLAMATION>;
            key-positions = <16 17>;
        };

        key2 {
            bindings = <&kp QUESTION>;
            key-positions = <28 29>;
        };

        scrl_up {
            bindings = <&msc MOVE_UP>;
            key-positions = <20 21>;
        };

        scrl_down {
            bindings = <&msc MOVE_DOWN>;
            key-positions = <32 33>;
        };

        left_shift {
            bindings = <&kp LEFT_SHIFT>;
            key-positions = <0 1>;
        };

        right_shift {
            bindings = <&kp LEFT_SHIFT>;
            key-positions = <8 9>;
        };
    };

    macros {
        safari_reload_once: safari_reload_once {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LGUI>,
                <&macro_tap>,
                <&kp R>,
                <&macro_release>,
                <&kp LGUI>;
        };

        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };

        /* Keep MB1 pressed */

        drag_on: drag_on {
            compatible = "zmk,behavior-macro";
            label = "DRAG_ON";
            #binding-cells = <0>;
            bindings = <&macro_press>, <&mkp MB1>;
        };

        /* Release MB1 */

        drag_off: drag_off {
            compatible = "zmk,behavior-macro";
            label = "DRAG_OFF";
            #binding-cells = <0>;
            bindings = <&macro_release>, <&mkp MB1>;
        };
    };

    behaviors {
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;

            #binding-cells = <2>;
            tapping-term-ms = <150>;
            flavor = "tap-preferred";
            hold-trigger-key-positions = <26>;
            quick-tap-ms = <90>;
        };

        enc_scroll: enc_scroll {
            compatible = "zmk,behavior-sensor-rotate-var";
            label = "ENC_SCROLL";
            #sensor-binding-cells = <2>;
            bindings = <&msc>, <&msc>;
        };

        rotate: rotate {
            compatible = "zmk,behavior-sensor-rotate";
            label = "ROTATE";
            #sensor-binding-cells = <0>;
            bindings = <&msc MOVE_UP>, <&msc MOVE_DOWN>;

            tap-ms = <20>;
        };

        lt_mkp: lt_mkp {
            compatible = "zmk,behavior-hold-tap";
            label = "LT_MKP";
            bindings = <&mo>, <&mkp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        mod_mkp: mod_mkp {
            compatible = "zmk,behavior-hold-tap";
            label = "MOD_MKP";
            bindings = <&kp>, <&mkp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        /* Tap: normal MB1 click / Hold: drag off (release MB1) */

        mb1_or_dragoff: mb1_or_dragoff {
            compatible = "zmk,behavior-hold-tap";
            label = "MB1_OR_DRAGOFF";
            bindings = <&drag_off>, <&mkp>;

            /* hold-tap は const で 2 固定 */

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            hold-trigger-on-release;
        };

        dragkey: dragkey {
            compatible = "zmk,behavior-hold-tap";
            label = "DRAGKEY";
            bindings = <&drag_on>, <&mkp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            require-prior-idle-ms = <150>;
            flavor = "tap-preferred";
            quick-tap-ms = <100>;
        };

        dragkey_off: dragkey_off {
            compatible = "zmk,behavior-hold-tap";
            label = "DRAGKEY_OFF";
            bindings = <&drag_off>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        encoder_msc_down_up: encoder_msc_down_up {
            compatible = "zmk,behavior-sensor-rotate";
            label = "ENCODER_MSC_DOWN_UP";
            #sensor-binding-cells = <0>;
            bindings = <&msc MOVE_DOWN>, <&msc MOVE_UP>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q             &kp W         &kp E         &kp R        &kp T                                                            &kp Y           &kp U               &lt 5 I    &kp O       &mt RIGHT_SHIFT P
&kp A             &kp S         &kp D         &kp F        &lt_to_layer_0 6 G  &kt LEFT_SHIFT       &kp AT_SIGN             &kp H           &kp J               &kp K      &lt 4 L     &lt 2 MINUS
&mt LEFT_SHIFT Z  &kp X         &kp C         &kp V        &kp B               &kp TAB              &mt LEFT_CONTROL COLON  &mt LEFT_ALT N  &mt LEFT_COMMAND M  &kp COMMA  &kp PERIOD  &lt 3 PLUS
&kp LCTRL         &kp LEFT_GUI  &kp LEFT_ALT  &lt 3 SPACE  &mkp MB1            &lt 2 LC(SPACE)      &kp BACKSPACE           &lt 1 ENTER                                                &kp DELETE
            >;

            sensor-bindings = <&inc_dec_kp DOWN_ARROW UP_ARROW>;
        };

        FUNCTION {
            bindings = <
&kp F5   &kp F4   &kp F3   &kp F2   &kp F1                                         &kp RIGHT_ALT      &kp LEFT_ARROW  &kp UP_ARROW    &kp RIGHT_ARROW  &kp CAPS
&kp F10  &kp F9   &kp F8   &kp F7   &kp F6   &kt LEFT_SHIFT         &kp RIGHT_GUI  &kp RIGHT_CONTROL  &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &kp ESC
&kp F11  &kp F17  &kp F16  &kp F15  &kp F14  &kp F13                &kp RG(A)      &kp RG(M)          &kp RG(Q)       &kp RG(W)       &kp RG(P)        &kp RS(RG(NUMBER_5))
&kp F12  &kp F19  &kp F18  &to 0    &kp F20  &kp LG(BACKSPACE)      &kp BACKSPACE  &trans                                                              &kp RS(RG(NUMBER_4))
            >;

            sensor-bindings = <&inc_dec_kp RIGHT_ARROW LEFT_ARROW>;
        };

        NUM {
            bindings = <
&kp KP_NUMBER_5       &kp KP_NUMBER_4  &kp KP_NUMBER_3  &kp KP_NUMBER_2  &kp KP_NUMBER_1                                     &kp CARET         &kp AMPERSAND      &kp TILDE       &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS
&kp KP_NUMBER_0       &kp KP_NUMBER_9  &kp KP_NUMBER_8  &kp KP_NUMBER_7  &kp KP_NUMBER_6  &kp LS(EQUAL)      &kp UNDERSCORE  &kp EXCLAMATION   &kp AT_SIGN        &kp HASH        &kp DOLLAR            &kp PERCENT
&mt LEFT_SHIFT COMMA  &kp PERIOD       &kp SLASH        &kp ASTERISK     &kp MINUS        &kp PLUS           &kp COLON       &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp LEFT_BRACE  &kp RIGHT_BRACE       &kp BACKSLASH
&trans                &trans           &trans           &to 0            &trans           &trans             &kp BACKSPACE   &kp ENTER                                                                  &kp PIPE
            >;

            sensor-bindings = <&inc_dec_kp TAB TAB>;
        };

        ARROW {
            bindings = <
&kp ESCAPE      &kp LC(LS(TAB))         &kp UP_ARROW    &kp LC(TAB)              &trans                                  &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp KP_NUMBER_3  &kp KP_NUMBER_4  &kp KP_NUMBER_5
&kp HOME        &kp LEFT_ARROW          &kp DOWN_ARROW  &kp RIGHT_ARROW          &kp END  &kp C_MUTE      &kp EQUAL      &kp KP_NUMBER_6  &kp KP_NUMBER_7  &kp KP_NUMBER_8  &kp KP_NUMBER_9  &kp KP_NUMBER_0
&kp LEFT_SHIFT  &kp LG(LS(LEFT_ARROW))  &kp DOWN_ARROW  &kp LG(LS(RIGHT_ARROW))  &trans   &trans          &kp PLUS       &kp MINUS        &kp ASTERISK     &kp SLASH        &kp PERIOD       &kp COMMA
&trans          &trans                  &trans          &to 0                    &trans   &trans          &kp BACKSPACE  &kp ENTER                                                           &kp RG(Z)
            >;

            sensor-bindings = <&inc_dec_kp C_VOLUME_DOWN C_VOLUME_UP>;
        };

        MOUSE {
            bindings = <
&mmv MOVE_LEFT       &mmv MOVE_DOWN  &mmv MOVE_UP  &mmv MOVE_RIGHT  &kp LG(T)                                            &kp LG(Z)  &mkp MB5        &lt_mkp 5 MB4  &kp LG(A)  &kp LC(H)
&msc MOVE_RIGHT      &msc MOVE_DOWN  &msc MOVE_UP  &msc MOVE_LEFT   &mo 11     &mkp MB3             &safari_reload_once  &mkp MB3   &mkp MB2        &mkp MB1       &none      &lt 5 ENTER
&mt LEFT_SHIFT HOME  &kp END         &mkp MB4      &mkp MB5         &mkp MB2   &kp TAB              &kp LG(C)            &kp LG(V)  &kp DOWN_ARROW  &kp UP_ARROW   &kp LG(X)  &lt 5 BACKSPACE
&trans               &trans          &trans        &kp LEFT_ARROW   &mkp MB1   &kp RIGHT_ARROW      &drag_off            &drag_on                                             &trans
            >;

            sensor-bindings = <&rotate>;
        };

        SCROLL {
            bindings = <
&mmv MOVE_LEFT   &mmv MOVE_DOWN  &mmv MOVE_UP  &mmv MOVE_RIGHT   &trans                                     &kp LEFT_SHIFT  &kp RIGHT_ALT  &trans  &kp RIGHT_CONTROL  &trans
&msc MOVE_RIGHT  &msc MOVE_DOWN  &msc MOVE_UP  &msc MOVE_LEFT    &trans  &to 0                 &trans       &trans          &trans         &trans  &trans             &trans
&trans           &trans          &trans        &trans            &trans  &trans                &trans       &trans          &trans         &trans  &trans             &trans
&trans           &trans          &trans        &kp LG(NUMBER_9)  &trans  &kp LG(NUMBER_0)      &kp PAGE_UP  &kp PAGE_DOWN                                             &trans
            >;

            sensor-bindings = <&inc_dec_kp LG(MINUS) LG(PLUS)>;
        };

        layer_6 {
            bindings = <
&trans  &trans  &trans  &trans  &trans                                              &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
&trans  &trans  &trans  &trans  &trans           &trans             &studio_unlock  &trans        &trans        &trans        &trans        &trans
&trans  &trans  &trans  &trans  &kp LG(LA(ESC))  &kp LC(LG(Q))      &bootloader     &trans        &trans        &trans        &trans        &bt BT_CLR
&trans  &trans  &trans  &trans  &trans           &trans             &trans          &trans                                                  &bt BT_CLR_ALL
            >;

            sensor-bindings = <&rotate>;
        };

        layer_7 {
            bindings = <
&trans                     &msc SCRL_UP  &msc SCRL_DOWN  &kp LC(PAGE_UP)  &kp LC(PAGE_DOWN)                              &kp LG(R)       &kp PAGE_UP  &kp PAGE_DOWN  &trans  &trans
&lt_to_layer_0 5 KP_MINUS  &mkp MB1      &mkp MB1        &mkp MB2         &trans             &mkp MB3      &trans        &mkp MB3        &mkp MB2     &mkp MB1       &trans  &lt_to_layer_0 5 KP_MINUS
&kp HOME                   &kp END       &mkp MB4        &mkp MB5         &mkp MB5           &trans        &trans        &trans          &mkp MB4     &mkp MB5       &trans  &trans
&trans                     &trans        &trans          &to 0            &trans             &trans        &msc SCRL_UP  &msc SCRL_DOWN                                      &trans
            >;

            sensor-bindings = <&rotate>;
        };

        /* Photoshop */

        PS_PHOTO {
            bindings = <
&kp V      &kp M          &kp C          &kp J          &kp B                               &kp LG(NUMBER_0)  &kp LG(NUMBER_1)  &kp LG(L)  &kp LG(M)  &kp LG(U)
&kp LG(J)  &kp LG(LS(N))  &kp LG(E)      &kp LG(COMMA)  &kp LG(DOT)    &to 0       &kp ESC  &trans            &trans            &trans     &trans     &trans
&kp LG(Z)  &kp LG(LS(Z))  &kp LG(LA(Z))  &kp LG(LS(S))  &kp LG(LA(S))  &trans      &trans   &trans            &trans            &trans     &trans     &trans
&trans     &trans         &trans         &mo 9          &trans         &mo 10      &trans   &trans                                                    &trans
            >;

            sensor-bindings = <&inc_dec_kp LG(MINUS) LG(PLUS)>;
        };

        PS_DRAW {
            bindings = <
&kp B   &kp E   &kp I   &kp X   &kp D                          &trans  &trans  &trans  &trans  &trans
&kp V   &kp M   &kp L   &kp J   &kp C   &kp LG(Z)      &trans  &trans  &trans  &trans  &trans  &trans
&kp Z   &kp A   &kp S   &kp F   &kp G   &trans         &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans         &trans  &trans                          &trans
            >;

            sensor-bindings = <&inc_dec_kp LG(MINUS) LG(PLUS)>;
        };

        PS_BRUSH {
            bindings = <
&trans  &trans  &trans  &trans  &trans                         &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &kp LG(Z)      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans         &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans         &trans  &trans                          &trans
            >;

            sensor-bindings = <&inc_dec_kp LBKT RBKT>;
        };

        layer_11 {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                          &trans
            >;

            sensor-bindings = <&inc_dec_kp F14 F15>;
        };
    };
};
